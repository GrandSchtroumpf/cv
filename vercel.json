{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        { "type": "header", "key": "x-vercel-ip-country", "value": "CA" }
      ],
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "header", "key": "x-vercel-ip-country", "value": "FR" }
      ],
      "destination": "/fr",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "header", "key": "x-vercel-ip-country", "value": "BE" }
      ],
      "destination": "/fr",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "header", "key": "x-vercel-ip-country", "value": "LU" }
      ],
      "destination": "/fr",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": false
    }
  ]
}
